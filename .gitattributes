# Auto-detect text files and normalize line endings to LF for everyone,
# regardless of each contributor's local core.autocrlf setting.
* text=auto eol=lf

# Be explicit for the file types in this project
*.py     text eol=lf
*.ini    text eol=lf
*.cfg    text eol=lf
*.mako   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.sql    text eol=lf

# Binary files should never be touched or diffed as text
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
